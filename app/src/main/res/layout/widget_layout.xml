<?xml version="1.0" encoding="utf-8"?>
<!--
    Widget layout — intentionally minimal.

    RemoteViews are very limited in which Views they support. We use a single
    ImageView to display a Bitmap drawn on a Canvas (in WidgetRenderer.kt).
    This allows us to render the circular progress ring and custom typography
    that RemoteViews cannot draw natively.

    The FrameLayout (widget_root) is the tap target for the PendingIntent.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="4dp">

    <ImageView
        android:id="@+id/widget_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:contentDescription="@string/widget_content_description" />

</FrameLayout>
